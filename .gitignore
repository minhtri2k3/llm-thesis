.env
.env.local
.env.production

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Data files (too large for git)
*.csv
*.parquet
data/

# ML model weights (too large for git — download on other machine)
fashion_agent/models/
*.safetensors
*.bin
*.pt
*.pth
*.onnx
