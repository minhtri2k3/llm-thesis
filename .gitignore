# Docker volumes
postgres_data/
qdrant_data/

# Backups (large archive files — restore manually, never commit)
pgdata_backup.tar.gz
qdrant_backup.tar.gz
fashion_agent/models_backup.tar.gz
fashion_agent/._models

# Compressed image dataset (too large for git)
fashion_agent/images/images_compressed/

