# ============================================================
# Fashion Agent RAG Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
PGDATABASE=fashion_rag
PGUSER=fashion_user
PG_PASSWORD=your_secure_password_here

# ── Gemini API ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Qdrant (optional — leave empty to disable auth) ────────
QDRANT_API_KEY=

# ── Cloudflare Tunnel (FE — clothie-web) ────────────────────
# Token for the "llm-thesis" tunnel that routes to clothie-web:80
# Cloudflare Dashboard → Zero Trust → Networks → Tunnels → llm-thesis
# Public Hostname service must be set to: http://clothie-web:80
CF_FE_TUNNEL_TOKEN=your_cloudflare_fe_tunnel_token_here
