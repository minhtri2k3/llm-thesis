# ============================================================
# Fashion Agent RAG Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
PGDATABASE=fashion_rag
PGUSER=fashion_user
PG_PASSWORD=your_secure_password_here

# ── Gemini API ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Qdrant (optional — leave empty to disable auth) ────────
QDRANT_API_KEY=

# ── Cloudflare Tunnel ───────────────────────────────────────
# Get token from: Cloudflare Dashboard → Zero Trust → Networks → Tunnels
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
