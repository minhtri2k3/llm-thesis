# PostgreSQL
PGDATABASE=fashion_rag
PGUSER=fashion_user
PGPASSWORD=your_db_password_here
PGHOST=localhost
PGPORT=5432

# Gemini
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant (no auth for local)
QDRANT_API_KEY=

# Dataset images path on host (for Docker volume mount)
DATASET_IMAGES_HOST_PATH=/path/to/your/images
DATASET_IMAGES_DIR=/path/to/your/images

# Cloudflare Tunnel (placeholder — fill when ready)
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# PG_PASSWORD for Docker Compose
PG_PASSWORD=your_db_password_here
